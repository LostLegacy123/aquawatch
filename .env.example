# Firebase (client-side, safe to expose in Vite)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Admin (server-side only — GitHub Actions, scraper, scripts/, Vercel api/)
# JSON string of service account key; also set as GitHub repo secret
FIREBASE_SERVICE_ACCOUNT=

# Telegram
VITE_TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_TOKEN=            # Functions, scripts/checkNotifications, Vercel api/telegram-webhook
TELEGRAM_GROUP_CHAT_ID=        # Daily digest group chat (Functions / sendDailyDigest)

# Discord
DISCORD_GROUP_WEBHOOK=         # Daily digest webhook (Functions / sendDailyDigest)
DISCORD_DEFAULT_WEBHOOK=       # optional fallback webhook
