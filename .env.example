# Firebase (client-side, safe to expose in Vite)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Admin (server-side only — GitHub Actions, scraper, scripts/, Vercel api/)
# Paste the full service account JSON on ONE line (minified), or set the same value in GitHub Secrets
FIREBASE_SERVICE_ACCOUNT=

# Telegram
# VITE_* = shown in the app (bot @username on Settings link screen)
VITE_TELEGRAM_BOT_USERNAME=
# Server-only: sends personal event DMs (scripts/, Vercel webhook, Functions) — never put in Vite client bundle
TELEGRAM_BOT_TOKEN=
# Server-only: group chat id for digest (negative number, e.g. -1001234567890)
TELEGRAM_GROUP_CHAT_ID=
# Server-only: your personal DM chat id (optional; also used for reminders)
TELEGRAM_CHAT_ID=
# Server-only: more ids comma-separated (optional)
TELEGRAM_CHAT_IDS=

# Discord
# Server-only: group news digest webhook (GitHub Actions or Functions)
DISCORD_GROUP_WEBHOOK=
# Not used by the app today — personal reminders use each user's webhook saved in Settings
DISCORD_DEFAULT_WEBHOOK=
